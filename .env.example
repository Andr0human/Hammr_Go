# Node role: controller | generator | standalone
HAMMR_ROLE=standalone

# Controller REST + Socket.IO (browser-facing)
HAMMR_PUBLIC_PORT=3000

# Controller WebSocket for generators (internal network in prod)
HAMMR_GEN_PORT=3001

# Generator-only: where to dial the controller
CONTROLLER_URL=ws://localhost:3001/gen

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=hammr
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# SQLite path (controller only)
SQLITE_PATH=./data/hammr.db

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Dashboard (apps/web) overrides — only needed when running the dev server
# against a controller on a different host. Defaults: REST proxied through
# Next dev rewrites; Socket.IO connects same-origin.
# CONTROLLER_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_CONTROLLER_ORIGIN=http://localhost:3000
