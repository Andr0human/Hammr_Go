{
  "name": "hammr",
  "version": "0.1.0",
  "private": true,
  "description": "Distributed HTTP load testing platform.",
  "workspaces": [
    "apps/node",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build -w @hammr/shared",
    "build:node": "npm run build -w @hammr/node",
    "dev:node": "npm run dev -w @hammr/node",
    "dev:web": "npm run dev -w @hammr/web",
    "lint": "eslint \"apps/**/src/**/*.{ts,tsx}\" \"packages/**/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml}\"",
    "migrate:clickhouse": "node apps/node/scripts/migrate-clickhouse.mjs",
    "smoke:undici": "tsx apps/node/scripts/undici-smoke.ts",
    "gen:demo": "tsx apps/node/scripts/generator-cli.ts",
    "test": "npm run test -w @hammr/node"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
