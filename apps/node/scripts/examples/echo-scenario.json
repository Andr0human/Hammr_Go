{
  "name": "Echo - Full User Flow",
  "baseUrl": "http://localhost:4000",
  "config": {
    "users": 100,
    "rampUp": "5s",
    "duration": "20s",
    "thinkTime": { "min": 50, "max": 150 }
  },
  "scenario": [
    {
      "name": "Login",
      "method": "POST",
      "path": "/api/auth/login",
      "body": { "email": "test@test.com", "password": "test123" },
      "extract": { "authToken": "$.token" },
      "thinkTime": 0
    },
    {
      "name": "Search Jobs",
      "method": "GET",
      "path": "/api/jobs?q=engineer",
      "headers": { "Authorization": "Bearer {{authToken}}" }
    },
    {
      "name": "Apply to Job",
      "method": "POST",
      "path": "/api/jobs/123/apply",
      "headers": { "Authorization": "Bearer {{authToken}}" }
    }
  ]
}
